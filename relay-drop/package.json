{
  "name": "relay-drop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "web": "vite --host 0.0.0.0 --port 4173",
    "peer": "peerjs --host 0.0.0.0 --port 9000 --path /peerjs",
    "dev": "concurrently -k \"npm:peer\" \"npm:web\"",
    "typecheck": "vue-tsc -b",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "start": "node server.mjs"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "express": "^5.1.0",
    "peer": "^1.0.2",
    "peerjs": "^1.5.5",
    "qrcode": "^1.5.4",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7"
  }
}
